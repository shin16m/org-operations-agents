{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.invalid/schemas/dept-work-complete.v1.schema.json",
  "title": "DeptWorkComplete",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "task_gid", "department", "status", "summary"],
  "properties": {
    "schema_version": { "type": "string", "const": "1.0" },
    "task_gid": { "type": "string", "minLength": 1 },
    "parent_gid": { "type": "string", "minLength": 1 },
    "department": {
      "type": "string",
      "enum": ["development", "analysis", "planning", "ux", "governance", "audit"]
    },
    "status": {
      "type": "string",
      "enum": ["completed", "blocked", "needs_rework"]
    },
    "summary": { "type": "string", "minLength": 1 },
    "artifacts": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    }
  }
}
