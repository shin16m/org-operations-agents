{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "MilestoneEffectivenessReport",
  "type": "object",
  "required": [
    "schema_version",
    "milestone_id",
    "title",
    "score",
    "status",
    "checklist_path",
    "checks",
    "gaps",
    "generated_at"
  ],
  "properties": {
    "schema_version": { "type": "string", "const": "1.0" },
    "milestone_id": { "type": "string", "minLength": 1 },
    "title": { "type": "string", "minLength": 1 },
    "tracker_gid": { "type": "string", "pattern": "^[0-9]+$" },
    "work_epic_gid": { "type": "string", "pattern": "^[0-9]+$" },
    "score": { "type": "number", "minimum": 0, "maximum": 100 },
    "status": {
      "type": "string",
      "enum": ["achieved", "warn", "not_achieved"]
    },
    "checklist_path": { "type": "string", "minLength": 1 },
    "axis_scores": {
      "type": "object",
      "properties": {
        "parts": { "type": "number", "minimum": 0, "maximum": 100 },
        "enforcement": { "type": "number", "minimum": 0, "maximum": 100 },
        "e2e": { "type": "number", "minimum": 0, "maximum": 100 }
      },
      "additionalProperties": false
    },
    "checks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "description", "check_type", "weight", "result"],
        "properties": {
          "id": { "type": "string" },
          "description": { "type": "string" },
          "check_type": {
            "type": "string",
            "enum": [
              "cli_help",
              "unittest",
              "file_exists",
              "rg_pattern",
              "validate_script",
              "manual_doc"
            ]
          },
          "weight": { "type": "number", "minimum": 0 },
          "axis": {
            "type": "string",
            "enum": ["parts", "enforcement", "e2e"]
          },
          "result": {
            "type": "string",
            "enum": ["pass", "fail", "skip"]
          },
          "detail": { "type": "string" }
        },
        "additionalProperties": true
      }
    },
    "gaps": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["check_id", "message"],
        "properties": {
          "check_id": { "type": "string" },
          "message": { "type": "string" },
          "severity": {
            "type": "string",
            "enum": ["P0", "P1", "P2", "P3"]
          }
        },
        "additionalProperties": true
      }
    },
    "follow_up_candidates": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["title", "department"],
        "properties": {
          "title": { "type": "string" },
          "department": { "type": "string" },
          "summary": { "type": "string" }
        },
        "additionalProperties": true
      }
    },
    "generated_at": { "type": "string", "minLength": 1 }
  },
  "additionalProperties": true
}
