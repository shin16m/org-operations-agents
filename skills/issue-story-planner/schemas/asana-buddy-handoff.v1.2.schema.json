{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.invalid/schemas/asana-buddy-handoff.v1.2.schema.json",
  "title": "AsanaBuddyHandoff",
  "description": "Handoff v1.2 — v1.1 plus optional subtasks[].department for task-dispatcher routing.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "epic", "subtasks"],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.2"
    },
    "meta": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "title": { "type": "string" },
        "locale": { "type": "string" }
      }
    },
    "epic": {
      "type": "object",
      "additionalProperties": false,
      "required": ["title", "notes_markdown"],
      "properties": {
        "title": { "type": "string", "minLength": 1 },
        "notes_markdown": { "type": "string", "minLength": 1 }
      }
    },
    "subtasks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["title", "background", "summary", "done_when"],
        "properties": {
          "title": { "type": "string", "minLength": 1 },
          "background": { "type": "string", "minLength": 1 },
          "summary": { "type": "string", "minLength": 1 },
          "done_when": { "type": "string", "minLength": 1 },
          "pillar": { "type": "string" },
          "department": {
            "type": "string",
            "enum": ["development", "analysis", "planning"],
            "description": "L2 dispatch target. Omitted → pillar_defaults heuristic."
          }
        }
      }
    }
  }
}
