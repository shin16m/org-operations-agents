# Asana API credentials (template — commit this file, not .env)
#
# Setup:
#   1. Copy this file to .env in the same directory:
#        copy .env.example .env          # cmd
#        Copy-Item .env.example .env     # PowerShell
#   2. Replace placeholder values below with your own.
#
# Discovery: scripts load the nearest .env from cwd or optional/ (see agent_handler_asana.load_env_from_dotfile).
# Shell env vars take precedence over .env (existing keys are not overwritten).

# Required — Personal Access Token from https://app.asana.com/0/my-apps
ASANA_TOKEN=your_personal_access_token

# Recommended — project GID for bootstrap (handoff_to_asana create mode).
# Also accepted: ASANA_PROJECT_GID, ASANA_PROJECT
# List projects: .\.venv\Scripts\python.exe .\skills\platform\asana-buddy\optional\handoff_to_asana.py --list-projects
ASANA_PROJECT_ID=your_project_gid

# Optional — section (list) GID; new parent tasks are added here after create.
# Example URL: .../project/<ASANA_PROJECT_ID>/list/<ASANA_SECTION_ID>
# Also accepted: ASANA_SECTION
ASANA_SECTION_ID=your_section_gid

# Optional — 担当種別 enum custom field
# AI = 担当メンバーが AI エージェント · human = 担当メンバーが人間（承認サブ等は org-ops が human を自動設定）
# List fields: GET /projects/{project_gid}/custom_field_settings
# Defaults match project 1214771428861230 if unset.
ASANA_ASSIGNEE_TYPE_FIELD_GID=1215082835199209
ASANA_ASSIGNEE_TYPE_AI_GID=1215082835199211
ASANA_ASSIGNEE_TYPE_HUMAN_GID=1215082835199210
# ASANA_ASSIGNEE_TYPE_DISABLED=true
