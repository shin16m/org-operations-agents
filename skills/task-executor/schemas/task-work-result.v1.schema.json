{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.invalid/schemas/task-work-result.v1.schema.json",
  "title": "TaskWorkResult",
  "description": "Output from task-executor after working an Asana subtask.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "task_gid", "status", "summary"],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0"
    },
    "task_gid": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": ["completed", "blocked", "needs_tool"]
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "delegated_to": {
      "type": "string"
    }
  }
}
