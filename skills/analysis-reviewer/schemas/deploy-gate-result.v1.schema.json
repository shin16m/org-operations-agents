{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.invalid/schemas/deploy-gate-result.v1.schema.json",
  "title": "DeployGateResult",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "status",
    "summary",
    "review_kind",
    "quality_approved",
    "security_approved",
    "sla_compliance"
  ],
  "properties": {
    "schema_version": { "type": "string", "const": "1.0" },
    "status": {
      "type": "string",
      "enum": ["passed", "passed_with_notes", "failed"]
    },
    "summary": { "type": "string", "minLength": 1 },
    "review_kind": { "type": "string", "const": "production_deploy_gate" },
    "quality_approved": { "type": "boolean" },
    "security_approved": { "type": "boolean" },
    "sla_compliance": { "type": "boolean" },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["severity", "message"],
        "properties": {
          "severity": { "type": "string", "enum": ["low", "medium", "high"] },
          "message": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
