# Python
__pycache__/
*.py[cod]
.venv/
venv/
.eggs/
*.egg-info/
.pytest_cache/
.mypy_cache/
dist/
build/

# Environment / secrets (.env.example is tracked)
.env
.env.*
!.env.example

# Logs
*.log

# OS
.DS_Store
Thumbs.db

# IDE (JetBrains; .vscode/ often committed — omitted)
.idea/

# Local scratch (Asana scans, PM notes — never commit)
.tmp*

# PM assign plans (epic-specific; folder kept via .gitkeep)
work/assign-plans/*
!work/assign-plans/.gitkeep

# Runtime artifacts (template: README + .gitkeep only)
output/**/*
!output/README.md
!output/**/README.md
!output/**/.gitkeep
